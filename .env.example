# Local
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Producción en Vercel: cambia por tu URL final.
# Ejemplo: https://tudominio.com o https://tu-proyecto.vercel.app
# NEXT_PUBLIC_SITE_URL=https://tudominio.com

# Supabase > Project Settings > API Keys / Data API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY_O_PUBLISHABLE_KEY

# Correo(s) autorizados para entrar a /admin.
# Para uno: ADMIN_EMAIL=tu-correo@email.com
# Para varios: ADMIN_EMAILS=correo1@email.com,correo2@email.com
ADMIN_EMAIL=tu-correo-admin@email.com
# ADMIN_EMAILS=correo1@email.com,correo2@email.com

# Solo servidor. Nunca usar con NEXT_PUBLIC.
# Legacy: service_role key. Nuevo sistema de Supabase: secret key equivalente para servidor.
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY_O_SECRET_KEY
